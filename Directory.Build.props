    <RepositoryType>git</RepositoryType>
    <RepositoryUrl>https://github.com/haiilong/LocalJob</RepositoryUrl>
    <PackageProjectUrl>https://github.com/haiilong/LocalJob</PackageProjectUrl>
  </PropertyGroup>
</Project>
